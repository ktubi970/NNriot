# Riot Games API key — get one at https://developer.riotgames.com/
RIOT_API_KEY=your_api_key_here

# SQLite database path (default: training_data.db in CWD)
NNRIOT_DB_PATH=training_data.db

# Flask web server
HOST=127.0.0.1
PORT=5000
FLASK_DEBUG=0

# Comma-separated CORS allowlist for the web API
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# Enable the mock OCR endpoint (returns hardcoded fake roster data)
# Set to 1 only for local testing of the live stream UI
MOCK_OCR_ENABLED=0
